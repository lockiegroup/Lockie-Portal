# Generate a strong random string: openssl rand -base64 32
JWT_SECRET=your-secret-key-here

# SMTP email settings (leave blank in dev to print OTP to console)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@lockie.com

# SQLite database path (defaults to ./lockie-portal.db)
DATABASE_PATH=./lockie-portal.db
